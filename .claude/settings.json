      "Bash(rm -rf *)",
      "Bash(del /s /q *)",
      "Bash(format *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git reset *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git add *)",
      "Bash(git rm *)",
      "Bash(git branch -D *)",
      "Bash(git tag *)",
      "Bash(git am *)",
      "Bash(git cherry-pick *)",
      "Bash(git revert *)"
    ]
  }
}
