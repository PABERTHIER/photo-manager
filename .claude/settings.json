{
  "permissions": {
    "allow": [
      "Bash(dotnet build *)",
      "Bash(dotnet test *)",
      "Bash(dotnet format *)",
      "Bash(dotnet restore *)",
      "Bash(dotnet run --project *Benchmarks*)",
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob"
    ],
